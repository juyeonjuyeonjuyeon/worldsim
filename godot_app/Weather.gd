# 맑을 때 기본 구름량 (0=청명, 1=흐림)
const CLOUD_BASE: Array = [
	[0.68,0.68,0.68,0.68,0.70,0.72,0.72,0.72,0.70,0.70,0.68,0.68],
	[0.22,0.18,0.18,0.25,0.60,0.70,0.72,0.72,0.65,0.50,0.28,0.22],
