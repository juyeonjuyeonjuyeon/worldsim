]

# 위도 + 월 → 기후 파라미터
static func get_params(latitude: float, month: int) -> Dictionary:
	var abs_lat := absf(latitude)
	var m: int = month - 1  # 0-indexed
	if latitude < 0.0:
		m = (month - 1 + 6) % 12  # 남반구 계절 반전

	var n: int = LAT_PTS.size()
	var pp: float = float(PRECIP_P[n-1][m])
	var sb: float = float(SNOW_BIAS[n-1][m])
	var rr: float = float(RAIN_RATE[n-1][m])
	var cb: float = float(CLOUD_BASE[n-1][m])

	for i in range(n - 1):
		if abs_lat <= float(LAT_PTS[i + 1]):
			var t: float = (abs_lat - float(LAT_PTS[i])) \
				/ (float(LAT_PTS[i + 1]) - float(LAT_PTS[i]))
			pp = lerp(float(PRECIP_P[i][m]),   float(PRECIP_P[i+1][m]),   t)
			sb = lerp(float(SNOW_BIAS[i][m]),  float(SNOW_BIAS[i+1][m]),  t)
			rr = lerp(float(RAIN_RATE[i][m]),  float(RAIN_RATE[i+1][m]),  t)
			cb = lerp(float(CLOUD_BASE[i][m]), float(CLOUD_BASE[i+1][m]), t)
			break

	return {
		"precip_prob":    pp,  # 강수 확률 0-1
		"snow_bias":      sb,  # 눈일 기후 경향 0-1
		"rain_rate_mean": rr,  # 강수 평균 강도 mm/hr
		"cloud_cover":    cb,  # 맑을 때 구름량 0-1
	}
